<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- 排除健康数据和语音记录 -->
        <exclude domain="database" path="health_profiles"/>
        <exclude domain="file" path="voice_records/"/>
        <exclude domain="file" path="photos/"/>
    </cloud-backup>
    <device-transfer>
        <!-- 设备传输时包含用户设置 -->
        <include domain="sharedpref" path="app_settings.xml"/>
        <include domain="database" path="dishes"/>
    </device-transfer>
</data-extraction-rules>